# Preserve binary-exact content (including BOM) for these files.
# Without this, autocrlf can rewrite line endings on Windows checkout,
# but more importantly some hosts may strip BOM on text normalization.
*.ps1   binary
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.conf  text eol=lf
*.ini   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.html  text eol=lf
*.php   text eol=lf
